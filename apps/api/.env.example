NODE_ENV=development
PORT=8787
ALLOWED_EXTENSION_ORIGIN=chrome-extension://your_extension_id_here

OPENAI_API_KEY=
HUBSPOT_PRIVATE_APP_TOKEN=

# Optional: set to true only after these custom Contact properties exist in HubSpot.
# If this is not enabled, AI details are saved to a HubSpot note instead.
HUBSPOT_SYNC_AI_CONTACT_PROPERTIES=false
HUBSPOT_AI_LEAD_SCORE_PROPERTY=ai_lead_score
HUBSPOT_AI_LEAD_FIT_PROPERTY=ai_lead_fit
HUBSPOT_AI_PERSONA_PROPERTY=ai_persona
HUBSPOT_AI_PAIN_POINTS_PROPERTY=ai_pain_points
HUBSPOT_AI_ICEBREAKER_PROPERTY=ai_icebreaker
HUBSPOT_AI_SUGGESTED_DM_PROPERTY=ai_suggested_dm
HUBSPOT_AI_NEXT_ACTION_PROPERTY=ai_next_action
HUBSPOT_AI_PERSONALIZATION_SCORE_PROPERTY=ai_personalization_score
HUBSPOT_AI_SPAM_RISK_PROPERTY=ai_spam_risk

# Development-only fallback. Production licenses should come from Stripe webhooks and PostgreSQL.
BETA_PRO_LICENSE_KEYS=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PAYMENT_LINK_ID=

LICENSE_EMAIL_WEBHOOK_URL=
ADMIN_SECRET=

# Local development can use file:./data/license-db.json.
# Production must use a managed PostgreSQL connection string.
DATABASE_URL=file:./data/license-db.json
