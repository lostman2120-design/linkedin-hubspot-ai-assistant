{
  "name": "linkedin-hubspot-ai-assistant",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "corepack pnpm --filter @linkedin-hubspot-ai/shared build && corepack pnpm --filter @linkedin-hubspot-ai/api build && corepack pnpm --filter @linkedin-hubspot-ai/extension build",
    "test": "corepack pnpm -r test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "license:create-tester": "corepack pnpm --filter @linkedin-hubspot-ai/api license:create-tester",
    "license:revoke": "corepack pnpm --filter @linkedin-hubspot-ai/api license:revoke",
    "license:inspect": "corepack pnpm --filter @linkedin-hubspot-ai/api license:inspect",
    "license:list-testers": "corepack pnpm --filter @linkedin-hubspot-ai/api license:list-testers"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.10.1",
    "eslint": "^9.15.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.16.0",
    "vitest": "^2.1.6"
  }
}
